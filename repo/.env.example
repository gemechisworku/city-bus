# Copy to .env and adjust. docker compose reads these automatically when present.

POSTGRES_DB=citybus
POSTGRES_USER=citybus
POSTGRES_PASSWORD=citybus
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=80

# JWT (Spring relaxed binding: app.jwt.secret → APP_JWT_SECRET). Use a long random value in production.
# REQUIRED: Set a strong, random secret of at least 64 hex characters before deployment.
APP_JWT_SECRET=CHANGE_ME_TO_RANDOM_VALUE_AT_LEAST_64_HEX_CHARS
APP_JWT_EXPIRATION_SECONDS=3600

# CORS allowed origins (comma-separated); default '*' for offline LAN
APP_CORS_ORIGINS=*
